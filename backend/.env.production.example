# ScopeIt Backend - Production Environment Variables
# Copy this to .env.production and fill in all values
# NEVER commit .env.production to git

# ===================
# Environment
# ===================
ENV=production
DEBUG=False

# ===================
# Database (Neon PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# ===================
DATABASE_URL=postgresql://scopeit:CHANGEME@ep-xxx.us-east-1.aws.neon.tech/scopeit?sslmode=require

# ===================
# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ===================
SECRET_KEY=CHANGEME_generate_with_python

# ===================
# CORS & URLs
# ===================
CORS_ORIGINS=https://scopeit.work,https://www.scopeit.work
FRONTEND_URL=https://scopeit.work

# ===================
# Google OAuth
# From: https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: https://api.scopeit.work/api/auth/google/callback
# ===================
GOOGLE_CLIENT_ID=CHANGEME
GOOGLE_CLIENT_SECRET=CHANGEME
GOOGLE_REDIRECT_URI=https://api.scopeit.work/api/auth/google/callback

# ===================
# AI / Anthropic
# From: https://console.anthropic.com/keys
# ===================
ANTHROPIC_API_KEY=CHANGEME

# ===================
# Beta Mode
# ===================
BETA_MODE=True
BETA_END_DATE=2026-06-30

# ===================
# Email (Optional - Phase 2)
# ===================
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=CHANGEME
EMAIL_FROM=noreply@scopeit.work
EMAIL_FROM_NAME=ScopeIt

# ===================
# Token Expiry
# ===================
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
